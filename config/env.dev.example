# Copy to news-pulse-frontend/.env.local for local development.
# Set the same hostname as NEWSMINE_DEV_HOST in news-pulse-backend/.env
# (run from repo root: ./scripts/dev-host.sh)

NEXT_PUBLIC_NEWSMINE_ENV=dev
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Firebase Auth (Google + phone OTP) — optional; omit to hide social/phone buttons
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Host only, no port — Next.js dev HMR when testing from a phone on Wi-Fi
# ALLOWED_DEV_ORIGINS=YourMac.local
